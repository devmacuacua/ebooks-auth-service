# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=8081

# ─── Base de dados (PostgreSQL) ───────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/auth_db
SPRING_DATASOURCE_USERNAME=ebooks
SPRING_DATASOURCE_PASSWORD=ebooks_secret

# ─── Redis (blacklist de tokens + rate limit) ─────────────────────────────────
SPRING_DATA_REDIS_URL=redis://localhost:6379

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_USERNAME=ebooks
SPRING_RABBITMQ_PASSWORD=ebooks_secret

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres; deve ser igual em todos os serviços que validam tokens
JWT_SECRET=muda_isto_em_producao_pelo_menos_32_chars!

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@ebooks.co.mz
SMTP_PASS=password_do_smtp
SMTP_FROM=noreply@ebooks.co.mz

# ─── Frontend (usado em links de email e redirecionamentos OAuth2) ────────────
FRONTEND_URL=http://localhost:3000

# ─── OAuth2 Social Login (opcional) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
